{
  "name": "@execbox/process",
  "version": "0.2.0",
  "description": "Child-process executor for the execbox core package.",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "sideEffects": false,
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsdown"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "child-process",
    "quickjs",
    "code-execution"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/aallam/execbox.git",
    "directory": "packages/process"
  },
  "homepage": "https://github.com/aallam/execbox/tree/main/packages/process#readme",
  "bugs": "https://github.com/aallam/execbox/issues",
  "dependencies": {
    "@execbox/core": "^0.3.0",
    "@execbox/protocol": "^0.2.0",
    "@execbox/quickjs": "^0.2.0"
  }
}
